<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout structure (bottom-up stacking in FrameLayout):
      1. WebView       — full screen, the GDevelop game
      2. bannerAdView  — sticky banner at bottom (GONE until ad loads)
      3. privacyPolicyBtn — floats above the banner
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Yandex sticky banner — size set programmatically in MainActivity -->
    <com.yandex.mobile.ads.banner.BannerAdView
        android:id="@+id/bannerAdView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:visibility="gone" />

    <!-- Privacy Policy button — native overlay above the banner -->
    <TextView
        android:id="@+id/privacyPolicyBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="70dp"
        android:layout_marginStart="12dp"
        android:background="#8C000000"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp"
        android:text="Privacy Policy"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:fontFamily="sans-serif"
        android:clickable="true"
        android:focusable="true" />

</FrameLayout>
